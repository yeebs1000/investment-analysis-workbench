# Copy this file to `.env` and fill in your values. `.env` is git-ignored.
# Everything has a safe default, so the app starts even with most fields blank —
# but you need at least a running Moomoo OpenD gateway for real data.

# --- Moomoo OpenD gateway (required; must be running and logged in) ---
OPEND_HOST=127.0.0.1
OPEND_PORT=11111
TRD_ENV=REAL                 # REAL | SIMULATE
TRD_MARKET=US                # US | HK | CN
SECURITY_FIRM=FUTUINC        # FUTUINC (Moomoo US) | FUTUSECURITIES (Futu HK) | FUTUAU | FUTUSG

# --- IBKR via IB Gateway / TWS (read-only, optional) ---
# Requires the gateway running with the API enabled.
IBKR_ENABLED=false           # true = merge IBKR holdings into the combined book
IBKR_HOST=127.0.0.1
IBKR_PORT=4001               # IB Gateway live=4001 paper=4002 ; TWS live=7496 paper=7497
IBKR_CLIENT_ID=1107

# --- Tiger Brokers via Tiger Open API (read-only, optional) ---
# From your Tiger app's Open API page. The private key file stays on your machine.
TIGER_ENABLED=false          # true = merge Tiger holdings into the combined book
TIGER_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY_PATH=      # e.g. C:/keys/tiger_private_key.pem

# --- Market data (Finnhub: search, analyst ratings, fundamentals, earnings, insiders) ---
# Free key at https://finnhub.io/register
FINNHUB_API_KEY=

# --- Macro data (FRED: yield curve / credit spread / VIX regime, optional) ---
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- LLM (optional; the app works fully without any key via "Deterministic") ---
# Gemini is the default. Claude only becomes selectable once its key is present.
GEMINI_API_KEY=              # https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=           # https://console.anthropic.com/  (optional)
DEFAULT_LLM=gemini           # gemini | claude | none
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-opus-4-8

# --- API server ---
API_HOST=127.0.0.1
API_PORT=8010
